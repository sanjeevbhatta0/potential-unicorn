{
  "version": 2,
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "echo 'no build needed'",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/sources/cron-crawl",
      "schedule": "0 12 * * *"
    }
  ]
}
